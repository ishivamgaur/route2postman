{
  "name": "route2postman",
  "version": "0.1.4",
  "description": "Framework-agnostic CLI that auto-detects your project's API framework and generates a Postman collection from your route definitions.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ishivamgaur/route2postman.git"
  },
  "bugs": {
    "url": "https://github.com/ishivamgaur/route2postman/issues"
  },
  "homepage": "https://github.com/ishivamgaur/route2postman#readme",
  "bin": {
    "route2postman": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "pack:dry-run": "npm pack --dry-run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "postman",
    "api",
    "routes",
    "express",
    "fastapi",
    "flask",
    "django",
    "hono",
    "gin"
  ],
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^12.1.0",
    "glob": "^11.0.1",
    "postman-collection": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.1",
    "@types/postman-collection": "^3.5.11",
    "typescript": "^5.8.3"
  }
}
